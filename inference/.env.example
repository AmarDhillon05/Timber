# ---------------------------------------------------------------------------
# Timber Blanket Inference API — environment configuration
# Copy this file to `.env` and fill in the values you need.
#   cp inference/.env.example inference/.env
# ---------------------------------------------------------------------------

# --- Models ----------------------------------------------------------------

# Audio Spectrogram Transformer (Hugging Face model id). The default is the
# AudioSet-finetuned AST and is downloaded automatically on first use.
AST_MODEL_ID=MIT/ast-finetuned-audioset-10-10-0.4593

# CLAP (Hugging Face model id). Downloaded automatically on first use.
CLAP_MODEL_ID=laion/clap-htsat-unfused

# BEATs is NOT on the HF Hub as a pipeline. Absolute path to the finetuned
# .pt checkpoint. Leave blank if you are not using the BEATs backend.
BEATS_CHECKPOINT=

# Optional: directory with the BEATs model code (BEATs.py, backbone.py, ...)
# and the AudioSet label CSV. Default to the bundled beats/ folder.
# BEATS_CODE_DIR=
# BEATS_LABELS_CSV=

# --- Hugging Face (optional) ----------------------------------------------

# Where HF caches downloaded weights. Leave blank for the default (~/.cache).
HF_HOME=
# Only needed for gated/private models.
HUGGING_FACE_HUB_TOKEN=

# --- Runtime ---------------------------------------------------------------

# Inference device: "auto" (cuda if available, else cpu), "cuda", or "cpu".
DEVICE=auto

# Model used when a /suggest request omits the ?model= query param.
DEFAULT_MODEL=clap

# --- API server ------------------------------------------------------------

API_HOST=0.0.0.0
API_PORT=8000

# Reject uploads larger than this (megabytes).
MAX_UPLOAD_MB=50
